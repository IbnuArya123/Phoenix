@using Phoenix.DTO.Account;
@model UpsertGuestDTO

@{
    Layout = "_AuthenticationLayout";
}

<h1>Sign Up</h1>
<form method="post" asp-action="Register">
    <div asp-validation-summary="All"></div>
    <input type="text" asp-for="Username" placeholder="Username..." autocomplete="off" />
    <input type="password" asp-for="Password" placeholder="Password..." />
    <input type="password" asp-for="ConfirmPassword" placeholder="Confirm Password..." />
    <input type="text" asp-for="FirstName" placeholder="First Name..." />
    <input type="text" asp-for="MiddleName" placeholder="Middle Name..." />
    <input type="text" asp-for="LastName" placeholder="Last Name..." />
    <span>BirthDate: </span><input type="date" asp-for="BirthDate"/>
    <div class="radio-section">
        <input type="radio" asp-for="Gender" value="M" />Male
        <input type="radio" asp-for="Gender" value="F" />Female
    </div>
    <input type="text" asp-for="Citizenship" placeholder="Citizenship..."/>
    <input type="text" asp-for="IDNumber" placeholder="ID Number..."/>
    <button type="submit">Sign Up</button>
</form>
<div class="link-container">
    <a asp-action="Login">Click untuk login</a>
</div>