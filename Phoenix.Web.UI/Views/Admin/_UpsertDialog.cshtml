<div class="popup-dialog upsert-popup">
    <header>
        <a href="javascript:;" class="close-button">
            <i class="fas fa-window-close"></i>
        </a>
    </header>
    @*<input type="hidden" class="id" value="0"/>*@
    <table>
        <tbody>
            <tr>
                <td>Username*: </td>
                <td>
                    <input class="username" />
                    <div class="validation-message" data-for="Username"></div>
                </td>
            </tr>
            <tr>
                <td>Job Title*: </td>
                <td>
                    <input class="job-title" />
                    <div class="validation-message" data-for="JobTitle"></div>
                </td>
            </tr>
        </tbody>
    </table>
    <button class="blue-button submit-button" type="submit" data-action="Insert"><span class="action"></span> Admin</button>
</div>